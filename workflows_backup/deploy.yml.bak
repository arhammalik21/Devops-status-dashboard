name: CI/CD Pipeline — Build, Push & Deploy

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  DOCKER_IMAGE: ${{ secrets.DOCKERHUB_USERNAME }}/devops-dashboard
  APP_VERSION: 1.0.${{ github.run_number }}

jobs:
  # ── Job 1: Build & Push Docker Image ───────────────────────────
  build-and-push:
    name: 🐳 Build & Push Docker Image
    runs-on: ubuntu-latest

    steps:
      - name: 📥 Checkout code
        uses: actions/checkout@v4

      - name: 🔐 Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKERHUB_USERNAME }}
          password: ${{ secrets.DOCKERHUB_TOKEN }}

      - name: 🏗️ Build Docker image
        run: |
          docker build \
            --build-arg APP_VERSION=${{ env.APP_VERSION }} \
            -t ${{ env.DOCKER_IMAGE }}:${{ env.APP_VERSION }} \
            -t ${{ env.DOCKER_IMAGE }}:${{ github.sha }} \
            -t ${{ env.DOCKER_IMAGE }}:latest \
            .

      - name: 📤 Push to Docker Hub
        if: github.event_name == 'push' && github.ref == 'refs/heads/main'
        run: |
          docker push ${{ env.DOCKER_IMAGE }}:${{ env.APP_VERSION }}
          docker push ${{ env.DOCKER_IMAGE }}:${{ github.sha }}
          docker push ${{ env.DOCKER_IMAGE }}:latest

  # ── Job 2: Deploy to AWS EC2 ───────────────────────────────────
  deploy:
    name: 🚀 Deploy to AWS EC2
    runs-on: ubuntu-latest
    needs: build-and-push
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'

    steps:
      - name: 🔑 Deploy via SSH
        uses: appleboy/ssh-action@v1.2.2
        with:
          host: ${{ secrets.EC2_HOST }}
          username: ${{ secrets.EC2_USER }}
          key: ${{ secrets.EC2_SSH_KEY }}
          script: |
            echo "🔄 Pulling latest image..."
            docker pull ${{ env.DOCKER_IMAGE }}:latest

            echo "🛑 Stopping old container (if running)..."
            docker stop devops-dashboard 2>/dev/null || true
            docker rm devops-dashboard 2>/dev/null || true

            echo "🚀 Starting new container..."
            docker run -d \
              --name devops-dashboard \
              --restart unless-stopped \
              -p 5000:5000 \
              -e APP_VERSION=${{ env.APP_VERSION }} \
              -e BUILD_NUMBER=${{ github.run_number }} \
              -e ENVIRONMENT=production \
              -e DEPLOY_TIME="$(date -u +'%Y-%m-%d %H:%M:%S UTC')" \
              ${{ env.DOCKER_IMAGE }}:latest

            echo "✅ Waiting for health check..."
            sleep 5
            curl -f http://localhost:5000/health || exit 1
            echo "✅ Deployment successful!"
